# Backend Environment Variables
# Copy this file to .env and fill in your values

# Server Configuration
PORT=5000
NODE_ENV=development

# JWT Secret - Change this to a secure random string in production!
JWT_SECRET=your-super-secret-key-change-this-in-production-12345

# WebSocket Configuration
WS_URL=ws://localhost:5000

# CORS Configuration (update these for production)
CORS_ORIGIN=http://localhost:3000

# Database (for future MongoDB/PostgreSQL integration)
# MONGODB_URI=mongodb://localhost:27017/study-room
# POSTGRES_URL=postgresql://user:password@localhost:5432/study-room

# Session Configuration
SESSION_SECRET=your-session-secret-key

# Rate Limiting (for production)
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=100

# Email Configuration (for future notifications)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
